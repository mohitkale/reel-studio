# Reel Studio environment variables.
# Copy to .env.local (git-ignored) or enter keys in the in-app Settings screen.
# Never commit real keys.
#
# Licensing: Reel Studio code is MIT. Remotion is the default video engine
# (Remotion License, not OSI open-source). HyperFrames projects use
# @hyperframes/producer (Apache-2.0) instead; no HyperFrames-specific env vars.
# Optional providers below have their own terms. See docs/LICENSING.md.

# Cartesia (https://docs.cartesia.ai) — vendor commercial terms apply
CARTESIA_API_KEY=

# ElevenLabs (https://elevenlabs.io/docs) — vendor commercial terms apply.
# Free/Starter plans work; the app falls back from wav_44100 to wav_24000 when needed.
ELEVENLABS_API_KEY=

# Google Gemini (optional AI scene generation) — Google AI terms apply
GEMINI_API_KEY=

# OpenAI (optional AI scene generation) — OpenAI terms apply
OPENAI_API_KEY=

# Unsplash (optional stock backgrounds for AI scenes — free Demo tier).
# Create an app at https://unsplash.com/oauth/applications and use its Access Key.
# Photos are under the Unsplash License; follow API attribution guidelines.
UNSPLASH_ACCESS_KEY=

# Jamendo (optional expanded music library — 600k+ Creative Commons tracks).
# Get a free Client ID at https://devportal.jamendo.com.
# Each track has its own CC license — check attribution before commercial use.
JAMENDO_CLIENT_ID=

# MCP server access token. Do NOT set this by hand — generate/rotate it in
# Settings → AI tools / MCP, then copy it into your AI tool's MCP config.
MCP_API_TOKEN=

# Optional: override render concurrency (integer >= 1).
# Leave empty to use adaptive defaults based on your machine.
REMOTION_RENDER_CONCURRENCY=

# Optional: how many render JOBS may run at once (integer >= 1, default 1).
# Each render spawns its own headless Chrome, so keep this low on small servers.
REEL_MAX_CONCURRENT_RENDERS=

# Optional: skip render smoke test in restricted CI environments.
# SKIP_RENDER_SMOKE=1
SKIP_RENDER_SMOKE=

# Local SQLite database for Prisma (resolved relative to prisma/)
DATABASE_URL="file:./dev.db"

# VoiceForge — self-hosted voice cloning (separate repo/service).
# Prefer 127.0.0.1 over localhost (avoids IPv6 ::1 mismatches on macOS).
# If Reel Studio runs in Docker and VoiceForge is on the host, use:
#   VOICEFORGE_SERVICE_URL=http://host.docker.internal:8089
# Engine model licenses vary (e.g. XTTS-v2 CPML is non-commercial) — see docs/LICENSING.md.
# First CPU synth per scene can take 1–10+ minutes; Reel Studio waits up to 10 min per scene.
VOICEFORGE_SERVICE_URL=http://127.0.0.1:8089
# Optional bearer token when VoiceForge is not open localhost (matches VOICEFORGE_API_TOKEN on the service).
VOICEFORGE_API_TOKEN=