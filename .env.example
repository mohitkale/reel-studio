# Reel Studio environment variables.
# Copy to .env.local (git-ignored) or enter keys in the in-app Settings screen.
# Never commit real keys.

# Cartesia (https://docs.cartesia.ai)
CARTESIA_API_KEY=

# ElevenLabs (https://elevenlabs.io/docs)
ELEVENLABS_API_KEY=

# Google Gemini (optional AI scene generation)
GEMINI_API_KEY=

# OpenAI (optional AI scene generation)
OPENAI_API_KEY=

# Unsplash (optional stock backgrounds for AI scenes — free Demo tier).
# Create an app at https://unsplash.com/oauth/applications and use its Access Key.
UNSPLASH_ACCESS_KEY=

# MCP server access token. Do NOT set this by hand — generate/rotate it in
# Settings → AI tools / MCP, then copy it into your AI tool's MCP config.
MCP_API_TOKEN=

# Optional: override render concurrency (integer >= 1).
# Leave empty to use adaptive defaults based on your machine.
REMOTION_RENDER_CONCURRENCY=

# Optional: skip render smoke test in restricted CI environments.
# SKIP_RENDER_SMOKE=1
SKIP_RENDER_SMOKE=

# Local SQLite database for Prisma (resolved relative to prisma/)
DATABASE_URL="file:./dev.db"
