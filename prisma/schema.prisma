// Reel Studio data model. SQLite for local-first; all access goes through the
// repository layer (src/library/repositories) so a future cloud DB swap is
// isolated. JSON-shaped columns are stored as strings and validated with Zod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  /// Video composition engine: "remotion" | "hyperframes"
  videoEngine String    @default("remotion")
  brandKitId  String?
  brandKit    BrandKit? @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scripts Script[]
}

model BrandKit {
  id          String   @id @default(cuid())
  name        String
  palette     String? // JSON: color token overrides
  fonts       String? // JSON: {fontFamily?}
  logoAssetId String?
  handle      String?
  ctaDefaults String? // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

model Script {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  fps            Int      @default(30)
  width          Int      @default(1080) // render canvas width (orientation)
  height         Int      @default(1920) // render canvas height (orientation)
  brandOverrides String? // JSON
  coverUrl       String? // cover/thumbnail image baked as the reel's opening frame
  musicUrl       String? // optional background music, mixed (ducked) under the voiceover
  musicVolume    Int      @default(20) // background music level, 0-100
  hideText          Boolean  @default(false) // global default: hide on-screen scene text
  hideProgressBar   Boolean  @default(false) // global: hide the top progress bar
  /// Voice workflow: "oneshot" (full take) | "per_scene" (clip library + assemble)
  voiceMode         String   @default("oneshot")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scenes     Scene[]
  takes      VoiceTake[]
  voiceClips SceneVoiceClip[]
  renders    Render[]

  @@index([projectId])
}

model Scene {
  id         String   @id @default(cuid())
  scriptId   String
  script     Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  order      Int
  templateId String   @default("placeholder")
  /// On-screen display text for the template.
  text       String
  /// Voiceover script. Null = same as `text` (most scenes).
  spokenText String?
  emphasis   String? // JSON array of emphasized phrases
  visual     String? // emoji, icon name, or stat value for the visual slot
  layoutJson String? // JSON
  assetRefs  String? // JSON array of asset ids
  hideText   Boolean? // per-scene override for on-screen text; null = inherit script default
  /// Active clip in per_scene voice mode; null = no selection.
  selectedVoiceClipId String? @unique
  selectedVoiceClip   SceneVoiceClip? @relation("SceneSelectedClip", fields: [selectedVoiceClipId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  voiceClips SceneVoiceClip[] @relation("SceneClips")

  @@index([scriptId, order])
}

model VoiceTake {
  id          String   @id @default(cuid())
  scriptId    String
  script      Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  label       String?
  providerId  String
  voiceId     String
  modelId     String?
  fps         Int      @default(30)
  totalFrames Int
  timingJson  String // JSON: [{ sceneId, startFrame, durationFrames, text }]
  audioPath   String // AssetStore key for the stitched WAV
  isPlaceholder Boolean @default(false)
  /// "oneshot" (full generate) | "assembled" (stitched from selected scene clips)
  source      String   @default("oneshot")
  createdAt   DateTime @default(now())

  @@index([scriptId])
}

/// User-facing per-scene voice versions (mix-and-match in per_scene mode).
model SceneVoiceClip {
  id             String   @id @default(cuid())
  scriptId       String
  script         Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  sceneId        String
  scene          Scene    @relation("SceneClips", fields: [sceneId], references: [id], onDelete: Cascade)
  providerId     String
  voiceId        String
  modelId        String?
  text           String // spoken text snapshot at synth time
  textHash       String
  audioPath      String // AssetStore key for this scene's WAV
  durationFrames Int
  fps            Int      @default(30)
  label          String?
  isPlaceholder  Boolean  @default(false)
  createdAt      DateTime @default(now())

  selectedByScene Scene? @relation("SceneSelectedClip")

  @@index([scriptId])
  @@index([sceneId, createdAt])
}

model Render {
  id            String   @id @default(cuid())
  scriptId      String
  script        Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  voiceTakeId   String?
  templateSetId String?
  name          String?
  status        String   @default("queued") // queued | rendering | done | error
  quality       String?  // "draft" | "standard" | "high"; null = "standard"
  progress      Float    @default(0)
  outputPath    String?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([scriptId])
}

// Per-scene synthesized-audio cache, keyed by exactly what determines the
// audio (scene, provider, voice, model, spoken text). Lets voice generation
// skip re-calling the TTS API for scenes that haven't changed since a prior
// take — a large speed win for iterative editing. Populated best-effort by
// take-service.ts; stale rows (text/voice changed) are simply ignored by future
// lookups and left for now rather than actively pruned.
model SceneAudioBeat {
  id         String   @id @default(cuid())
  scriptId   String
  sceneId    String
  providerId String
  voiceId    String
  modelId    String   @default("") // normalized: "" when the provider has no model concept
  textHash   String
  audioPath  String // AssetStore key for this single scene's WAV
  createdAt  DateTime @default(now())

  @@unique([sceneId, providerId, voiceId, modelId, textHash])
  @@index([scriptId])
}

model Asset {
  id        String   @id @default(cuid())
  type      String // image | lottie | audio | 3d | avatar
  name      String?
  path      String // AssetStore key
  meta      String? // JSON
  createdAt DateTime @default(now())
}

model ProviderSetting {
  providerId   String  @id
  hasKey       Boolean @default(false)
  defaultModel String?
}

/// Voice-only multi-speaker podcast (separate from video Project/Script).
model Podcast {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  /// Target length hint for AI/JSON: "short" (~2-3 min) | "long" (~5-10 min)
  length      String   @default("short")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  characters PodcastCharacter[]
  turns      PodcastTurn[]
  takes      PodcastTake[]
}

model PodcastCharacter {
  id         String   @id @default(cuid())
  podcastId  String
  podcast    Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  /// Stable id for JSON/AI (e.g. "host", "guest")
  key        String
  name       String
  /// "male" | "female" | "neutral"
  gender     String   @default("neutral")
  /// Personality / role brief used when AI writes this character's lines.
  definition String   @default("")
  providerId String   @default("")
  voiceId    String   @default("")
  modelId    String?
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  turns PodcastTurn[]

  @@unique([podcastId, key])
  @@index([podcastId, order])
}

model PodcastTurn {
  id          String           @id @default(cuid())
  podcastId   String
  podcast     Podcast          @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  characterId String
  character   PodcastCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  order       Int
  text        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([podcastId, order])
}

model PodcastTake {
  id          String   @id @default(cuid())
  podcastId   String
  podcast     Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  label       String?
  /// Metadata from first character voice used (mixed takes use multiple voices).
  providerId  String
  voiceId     String
  modelId     String?
  fps         Int      @default(30)
  totalFrames Int
  /// JSON: [{ turnId, startFrame, durationFrames, text, characterKey? }]
  timingJson  String
  audioPath   String
  createdAt   DateTime @default(now())

  @@index([podcastId])
}
